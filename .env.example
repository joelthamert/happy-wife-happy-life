# Copy to .env.local (gitignored) and fill in ONE of these — either works.
# Ticketmaster: developer.ticketmaster.com (free, may take a little while to approve)
VITE_TM_API_KEY=PASTE_YOUR_KEY_HERE
# SeatGeek: seatgeek.com/account/develop (free, client_id issued instantly)
VITE_SEATGEEK_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE

# Supabase — couples mode (free instant project at supabase.com; run supabase/schema.sql once)
VITE_SUPABASE_URL=PASTE_YOUR_PROJECT_URL
VITE_SUPABASE_ANON_KEY=PASTE_YOUR_ANON_KEY

# Google sign-in (console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
VITE_GOOGLE_CLIENT_ID=PASTE_YOUR_CLIENT_ID
